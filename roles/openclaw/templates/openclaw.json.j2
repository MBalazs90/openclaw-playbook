{
  "gateway": {
    "mode": "local",
    "trustedProxies": ["127.0.0.1", "::1", "172.16.0.0/12"],
    "auth": {
      "mode": "trusted-proxy",
      "trustedProxy": {
        "userHeader": "Tailscale-User-Login"
      }
    },
    "controlUi": {
      "allowedOrigins": ["https://{{ tailscale_hostname }}"]
    }
  },
  "agents": {
    "defaults": {
      "model": {
        "primary": "moonshot/kimi-k2.5"
      }
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
{% if moonshot_api_key %}
      "moonshot": {
        "baseUrl": "https://api.moonshot.ai/v1",
        "apiKey": "${MOONSHOT_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "kimi-k2.5", "name": "Kimi K2.5" }
        ]
      }{{ "," if anthropic_api_key or openai_api_key else "" }}
{% endif %}
{% if anthropic_api_key %}
      "anthropic": {
        "apiKey": "${ANTHROPIC_API_KEY}",
        "models": [
          { "id": "claude-sonnet-4-6", "name": "Claude Sonnet 4.6" },
          { "id": "claude-opus-4-6", "name": "Claude Opus 4.6" }
        ]
      }{{ "," if openai_api_key or minimax_api_key else "" }}
{% endif %}
{% if openai_api_key %}
      "openai": {
        "baseUrl": "https://api.openai.com/v1",
        "apiKey": "${OPENAI_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "gpt-4o", "name": "GPT-4o" },
          { "id": "o3", "name": "o3" }
        ]
      }{{ "," if minimax_api_key else "" }}
{% endif %}
{% if minimax_api_key %}
      "minimax": {
        "baseUrl": "https://api.minimaxi.chat/v1",
        "apiKey": "${MINIMAX_API_KEY}",
        "api": "openai-completions",
        "models": [
          { "id": "MiniMax-M1", "name": "MiniMax M1" },
          { "id": "MiniMax-M2.5", "name": "MiniMax M2.5" }
        ]
      }
{% endif %}
    }
  }
}
