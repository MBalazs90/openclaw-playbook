# Managed by Ansible — do not edit manually
# {{ ansible_managed }}

# ---------------------------------------------------------------------------
# Gateway
# ---------------------------------------------------------------------------
OPENCLAW_GATEWAY_TOKEN={{ openclaw_gateway_token }}
# Inside the container, bind to all interfaces so Docker port-forwarding works.
# Host-side security is enforced by binding Docker ports to 127.0.0.1 only.
OPENCLAW_GATEWAY_BIND=lan

# Docker compose vars
OPENCLAW_IMAGE={{ openclaw_image_name }}:{{ openclaw_image_tag }}
OPENCLAW_CONFIG_DIR={{ openclaw_config_dir }}
OPENCLAW_WORKSPACE_DIR={{ openclaw_workspace_dir }}
OPENCLAW_GATEWAY_PORT={{ openclaw_gateway_port }}
OPENCLAW_BRIDGE_PORT={{ openclaw_bridge_port }}

# ---------------------------------------------------------------------------
# Model provider API keys
# ---------------------------------------------------------------------------
{% if moonshot_api_key %}
MOONSHOT_API_KEY={{ moonshot_api_key }}
{% endif %}
{% if anthropic_api_key %}
ANTHROPIC_API_KEY={{ anthropic_api_key }}
{% endif %}
{% if openai_api_key %}
OPENAI_API_KEY={{ openai_api_key }}
{% endif %}
{% if minimax_api_key %}
MINIMAX_API_KEY={{ minimax_api_key }}
{% endif %}

# ---------------------------------------------------------------------------
# Channels
# ---------------------------------------------------------------------------
{% if telegram_bot_token %}
TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
{% endif %}
{% if discord_bot_token %}
DISCORD_BOT_TOKEN={{ discord_bot_token }}
{% endif %}
{% if slack_bot_token %}
SLACK_BOT_TOKEN={{ slack_bot_token }}
{% endif %}
{% if slack_app_token %}
SLACK_APP_TOKEN={{ slack_app_token }}
{% endif %}
